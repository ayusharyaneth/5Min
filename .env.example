# Telegram Bot Configuration
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
TELEGRAM_CHAT_ID=123456789

# Trading Mode: 'paper' (simulation) or 'live' (real money)
TRADING_MODE=paper

# Shimmer API (Paper Trading / Simulation)
SHIMMER_API_KEY=your_shimmer_api_key_here
SHIMMER_URL=https://api.shimmer.network

# Polymarket (Live Trading) - Only needed if TRADING_MODE=live
# WARNING: Real money at risk
POLYMARKET_PK=0x_your_private_key_here
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_SECRET=your_polymarket_secret
POLYMARKET_WALLET_ADDRESS=0x_your_wallet_address

# Trading Parameters
INITIAL_BALANCE=10000.0
MAX_TRADE_SIZE=100.0
AUTO_TRADE=false
DEFAULT_TRADE_SIZE=1.0

# Database
DB_PATH=trades.db

# Feature Flags
MOCK_MODE=true
CONFIRM_TRADES=true
NOTIFICATIONS_ENABLED=true
